---
import '../styles/tokens.css';
import '../styles/global.css';
import Sidebar from './Sidebar.astro';
import { listCollections } from '../lib/collections';
import { listImports } from '../lib/imports';
import { listPhotos } from '../lib/catalog';

interface Props {
  title?: string;
  activeCollection?: string;
  activeRoot?: 'all' | 'collection' | 'imports' | 'orphans';
}

const {
  title = 'photography',
  activeCollection,
  activeRoot = activeCollection ? 'collection' : 'all',
} = Astro.props;

const [collections, imports, photos] = await Promise.all([
  listCollections(),
  listImports(),
  listPhotos(),
]);
const importsCount = imports.length;
const orphansCount = photos.filter((p) => p.collections.length === 0).length;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <script is:inline>
      (function () {
        var stored = null;
        try {
          stored = localStorage.getItem('theme');
        } catch (e) {}
        document.documentElement.dataset.theme = stored === 'dark' ? 'dark' : 'light';
      })();
    </script>
  </head>
  <body>
    <div class="app">
      <Sidebar
        collections={collections}
        activeCollection={activeCollection}
        activeRoot={activeRoot}
        importsCount={importsCount}
        orphansCount={orphansCount}
      />
      <main class="main">
        <slot />
      </main>
    </div>
  </body>
</html>

<style>
  .app {
    display: grid;
    grid-template-columns: var(--sidebar-w) 1fr;
    min-height: 100vh;
  }
  .main {
    padding: 28px 36px 60px;
    min-width: 0;
  }
</style>
