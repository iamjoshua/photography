---
import type { Photo } from '../types';

interface Props {
  photo: Photo;
  /** When set, this card is rendered inside a specific collection's view */
  collectionContext?: string;
}

const { photo, collectionContext } = Astro.props;

const locParts = [
  photo.location?.sublocation,
  photo.location?.city,
  photo.location?.state,
].filter(Boolean);
const locText = locParts.join(', ');
---

<article
  class="card"
  data-photo-id={photo.id}
  data-photo-path={photo.path}
  data-photo-filename={photo.filename}
  data-photo-collections={photo.collections.join(',')}
  data-collection-context={collectionContext ?? ''}
>
  <button
    class="thumb"
    data-action="open-lightbox"
    aria-label={`Open large preview of ${photo.filename}`}
  >
    {
      photo.hasSmall ? (
        <img
          src={`/api/img/small/${photo.id}.webp`}
          alt={photo.filename}
          loading="lazy"
        />
      ) : (
        <div class="missing">no thumbnail</div>
      )
    }
    {
      !photo.hasLarge && (
        <span class="badge" title="No large variant generated">!</span>
      )
    }
  </button>

  <button
    class="menu-btn"
    data-action="open-menu"
    aria-label="Photo actions"
  >
    <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" aria-hidden="true">
      <circle cx="3" cy="8" r="1.4" />
      <circle cx="8" cy="8" r="1.4" />
      <circle cx="13" cy="8" r="1.4" />
    </svg>
  </button>

  <div class="meta">
    <div class="filename" title={photo.filename}>{photo.filename}</div>
    {locText && <div class="loc">{locText}</div>}
    {
      photo.collections.length > 0 && (
        <div class="chips">
          {photo.collections.map((c) => (
            <span class="chip" class:list={[c === collectionContext && 'chip-active']}>
              {c}
            </span>
          ))}
        </div>
      )
    }
  </div>
</article>

<style>
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .thumb {
    all: unset;
    position: relative;
    cursor: zoom-in;
    display: block;
    aspect-ratio: 3 / 2;
    background: var(--surface);
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    transition: border-color var(--transition);
  }
  .thumb:hover {
    border-color: var(--border-strong);
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 250ms ease;
  }
  .card:hover .thumb img {
    transform: scale(1.015);
  }
  .missing {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-faint);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .badge {
    position: absolute;
    bottom: 6px;
    left: 6px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--danger);
    color: white;
    font-size: 10px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }
  .menu-btn {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: none;
    background: var(--bg-overlay);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    color: var(--text);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(-2px);
    transition:
      opacity var(--transition),
      transform var(--transition),
      background var(--transition);
    cursor: pointer;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
  }
  .card:hover .menu-btn,
  .menu-btn:focus-visible,
  .card.menu-open .menu-btn {
    opacity: 1;
    transform: translateY(0);
  }
  .menu-btn:hover {
    background: var(--bg);
  }
  .meta {
    padding: 0 2px;
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }
  .filename {
    font-size: 12px;
    color: var(--text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }
  .loc {
    font-size: 11px;
    color: var(--text-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .chips {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
    margin-top: 3px;
  }
  .chip {
    font-size: 10px;
    padding: 1px 6px;
    border-radius: 999px;
    background: transparent;
    color: var(--text-muted);
    border: 1px solid var(--border);
    line-height: 1.6;
  }
  .chip-active {
    background: var(--surface);
    color: var(--text);
    border-color: var(--border-strong);
  }
</style>
