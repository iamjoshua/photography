---
import PhotoCard from './PhotoCard.astro';
import type { Photo } from '../types';

interface Props {
  photos: Photo[];
  collectionContext?: string;
  coverPath?: string;
  emptyText?: string;
}

const { photos, collectionContext, coverPath, emptyText = 'No photos.' } = Astro.props;
---

{
  photos.length === 0 ? (
    <div class="empty">{emptyText}</div>
  ) : (
    <div class="grid">
      {photos.map((p) => (
        <PhotoCard photo={p} collectionContext={collectionContext} coverPath={coverPath} />
      ))}
    </div>
  )
}

<script>
  import { initLightbox } from './Lightbox';
  import { initPhotoMenu } from './PhotoMenu';
  initLightbox();
  initPhotoMenu();
</script>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 22px 18px;
  }
  .empty {
    padding: 80px 0;
    text-align: center;
    color: var(--text-faint);
    font-size: 13px;
  }
</style>
