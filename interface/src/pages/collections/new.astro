---
import Layout from '../../components/Layout.astro';
---

<Layout title="New collection">
  <header class="head">
    <h1>New collection</h1>
    <p class="sub">
      Defines a new YAML at <code>data/collections/&lt;name&gt;.yaml</code>.
      Filters are optional — leave blank to manage photos manually.
    </p>
  </header>

  <form id="form" class="form">
    <label>
      <span>Title</span>
      <input name="title" required placeholder="Seattle Pics" autocomplete="off" autofocus />
    </label>
    <label>
      <span>Name <small>(slug, becomes the yaml filename and URL — auto-derived from title; clear to resync)</small></span>
      <input name="name" required pattern="[a-z0-9-]+" placeholder="seattle-pics" autocomplete="off" />
    </label>
    <label>
      <span>Description</span>
      <textarea name="description" rows="3" placeholder="Optional"></textarea>
    </label>

    <fieldset>
      <legend>Filters</legend>
      <div class="grid-2">
        <label>
          <span>Keywords</span>
          <input name="keywords" placeholder="nature, sunset" autocomplete="off" />
        </label>
        <label>
          <span>Location</span>
          <input name="location" placeholder="Seattle" autocomplete="off" />
        </label>
        <label>
          <span>Rating</span>
          <input name="rating" placeholder="4+" autocomplete="off" />
        </label>
        <label>
          <span>Date</span>
          <input name="date" placeholder="2025" autocomplete="off" />
        </label>
      </div>
    </fieldset>

    <div class="actions">
      <button type="submit" id="submit">Create</button>
      <a href="/" class="cancel">Cancel</a>
      <span id="status" class="status"></span>
    </div>
  </form>

  <script>
    const form = document.getElementById('form') as HTMLFormElement;
    const status = document.getElementById('status')!;
    const submit = document.getElementById('submit') as HTMLButtonElement;
    const titleInput = form.elements.namedItem('title') as HTMLInputElement;
    const nameInput = form.elements.namedItem('name') as HTMLInputElement;

    // Final slug form (no trailing hyphens) — used for title→name auto-fill
    // and submit-time safety.
    function slugify(s: string): string {
      return s
        .toLowerCase()
        .normalize('NFD')
        .replace(/[̀-ͯ]/g, '')
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-+|-+$/g, '');
    }

    // Live slug form for use while the user is typing into Name. Preserves
    // a trailing hyphen so "hamilton " visibly becomes "hamilton-" instead
    // of swallowing the just-typed space.
    function slugifyLive(s: string): string {
      return s
        .toLowerCase()
        .normalize('NFD')
        .replace(/[̀-ͯ]/g, '')
        .replace(/[^a-z0-9-]+/g, '-')
        .replace(/-+/g, '-')
        .replace(/^-+/, '');
    }

    // Name auto-derives from title until the user manually overrides it.
    // Clearing the name field re-enables auto-derivation.
    let nameManual = false;

    titleInput.addEventListener('input', () => {
      if (!nameManual) {
        nameInput.value = slugify(titleInput.value);
      }
    });

    nameInput.addEventListener('input', () => {
      const raw = nameInput.value;
      const cleaned = slugifyLive(raw);
      if (raw !== cleaned) {
        const atEnd = nameInput.selectionStart === raw.length;
        nameInput.value = cleaned;
        if (atEnd) nameInput.setSelectionRange(cleaned.length, cleaned.length);
      }
      if (nameInput.value === '') {
        nameManual = false;
        return;
      }
      if (nameInput.value !== slugify(titleInput.value)) {
        nameManual = true;
      }
    });

    // On blur, collapse the trailing hyphen (if any) to the final slug form.
    // If Name was left empty, refill from the current Title (and re-enable
    // auto-sync since the user clearly didn't want a custom slug).
    nameInput.addEventListener('blur', () => {
      if (nameInput.value === '' && titleInput.value !== '') {
        nameInput.value = slugify(titleInput.value);
        nameManual = false;
        return;
      }
      nameInput.value = slugify(nameInput.value);
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      // Safety net: if name was cleared and never refilled, derive on submit.
      if (!nameInput.value && titleInput.value) {
        nameInput.value = slugify(titleInput.value);
      }
      submit.disabled = true;
      status.textContent = 'Creating…';
      const data = Object.fromEntries(new FormData(form));
      const res = await fetch('/api/collections/create', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (res.ok) {
        const out = await res.json();
        location.href = `/collections/${out.name}`;
      } else {
        status.textContent = '';
        submit.disabled = false;
        alert(`Create failed:\n\n${await res.text()}`);
      }
    });
  </script>
</Layout>

<style>
  .head { margin-bottom: 24px; max-width: 560px; }
  h1 { margin: 0; font-size: 20px; font-weight: 600; letter-spacing: -0.01em; }
  .sub {
    margin: 6px 0 0;
    font-size: 12.5px;
    color: var(--text-muted);
  }
  .sub code {
    font-family: ui-monospace, SF Mono, Menlo, monospace;
    font-size: 12px;
    background: var(--surface);
    padding: 1px 5px;
    border-radius: 3px;
  }
  .form {
    max-width: 520px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  label {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  label > span {
    font-size: 12px;
    color: var(--text-muted);
    font-weight: 500;
  }
  label > span small {
    font-weight: 400;
    color: var(--text-faint);
    margin-left: 4px;
  }
  input,
  textarea {
    font: inherit;
    padding: 8px 10px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg);
    color: var(--text);
    transition: border-color var(--transition);
  }
  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--accent);
  }
  textarea { resize: vertical; }
  fieldset {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 14px 16px 16px;
    margin: 0;
  }
  legend {
    font-size: 11px;
    color: var(--text-muted);
    padding: 0 6px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  .actions {
    display: flex;
    gap: 14px;
    align-items: center;
  }
  button[type='submit'] {
    font: inherit;
    padding: 8px 16px;
    background: var(--text);
    color: var(--bg);
    border: none;
    border-radius: var(--radius);
    cursor: pointer;
    font-weight: 500;
    transition: opacity var(--transition);
  }
  button[type='submit']:hover { opacity: 0.85; }
  button[type='submit']:disabled { opacity: 0.5; cursor: wait; }
  .cancel {
    font-size: 13px;
    color: var(--text-muted);
  }
  .cancel:hover { color: var(--text); }
  .status {
    font-size: 12px;
    color: var(--text-muted);
  }
</style>
