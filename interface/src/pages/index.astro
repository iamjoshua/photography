---
import Layout from '../components/Layout.astro';
import PhotoGrid from '../components/PhotoGrid.astro';
import { listPhotos } from '../lib/catalog';

const photos = await listPhotos();
---

<Layout title="All photos — portfolio" activeRoot="all">
  <header class="head">
    <div class="title-row">
      <h1>All photos</h1>
      <span class="count">{photos.length}</span>
    </div>
    <p class="sub">
      Every photo in the portfolio. Click a thumbnail to proof the large variant.
    </p>
  </header>
  <PhotoGrid photos={photos} />
</Layout>

<style>
  .head {
    margin-bottom: 24px;
  }
  .title-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }
  h1 {
    margin: 0;
    font-size: 20px;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .count {
    font-size: 12px;
    color: var(--text-faint);
    font-variant-numeric: tabular-nums;
  }
  .sub {
    margin: 4px 0 0;
    font-size: 12.5px;
    color: var(--text-muted);
  }
</style>
