---
import Layout from '../components/Layout.astro';
import PhotoGrid from '../components/PhotoGrid.astro';
import { listPhotos } from '../lib/catalog';

const allPhotos = await listPhotos();
const photos = allPhotos.filter((p) => p.collections.length === 0);
---

<Layout title="Orphans — portfolio" activeRoot="orphans">
  <header class="head">
    <div class="title-row">
      <h1>Orphans</h1>
      <span class="count">{photos.length}</span>
    </div>
    <p class="sub">
      Photos in the catalog that aren't a member of any collection. Use the
      3-dot menu to add them to one.
    </p>
  </header>
  <PhotoGrid
    photos={photos}
    emptyText="No orphaned photos. Every photo is in at least one collection."
  />
</Layout>

<style>
  .head {
    margin-bottom: 24px;
  }
  .title-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }
  h1 {
    margin: 0;
    font-size: 20px;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .count {
    font-size: 12px;
    color: var(--text-faint);
    font-variant-numeric: tabular-nums;
  }
  .sub {
    margin: 4px 0 0;
    font-size: 12.5px;
    color: var(--text-muted);
    max-width: 640px;
  }
</style>
