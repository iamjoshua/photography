#!/bin/bash

# Remove a single photo from a single collection's yaml.
#
# Usage:
#   ./scripts/remove-from-collection <collection-name> <photo-path>

if [ -z "$1" ] || [ -z "$2" ]; then
  echo "Usage: ./scripts/remove-from-collection <collection-name> <photo-path>"
  exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
python3 "$SCRIPT_DIR/utils/remove_from_collection.py" "$@"
