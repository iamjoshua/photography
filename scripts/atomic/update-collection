#!/bin/bash

# Patch a collection's title, description, and/or cover_path.
#
# Usage:
#   ./scripts/atomic/update-collection <collection-name> \
#       [--title T] [--description D] [--cover-path PATH]

if [ -z "$1" ]; then
  echo "Usage: ./scripts/atomic/update-collection <collection-name> [--title T] [--description D] [--cover-path PATH]"
  exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
python3 "$SCRIPT_DIR/utils/update_collection.py" "$@"
